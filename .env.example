# 应用配置
APP_NAME=InsurGuide
APP_VERSION=1.0.0
DEBUG=True

# JWT 配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=ZhiBao123**
MYSQL_DATABASE=insurguide

# Redis 配置（多轮对话上下文，必选用于 /api/chat）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=ZhiBao123**
REDIS_CONTEXT_TTL_MINUTES=30
REDIS_MAX_HISTORY_TURNS=10

# RAGflow 配置（知识库检索，必选用于增强 RAG）
RAGFLOW_API_URL=http://47.118.30.223:9380/api/v1
RAGFLOW_API_KEY=ragflow-dDrIbMcOZLzb9TlZ7WTRdkZlq-Ue_kKWI-pCPdtHKOw
RAGFLOW_KNOWLEDGE_BASE_ID=7f6af9a5080c11f1a760fe457711635e
RAGFLOW_TOP_K=3
RAGFLOW_TIMEOUT=10

# 答案生成：api=通义/OpenAI，local=本地 Qwen
LLM_MODE=api
DASHSCOPE_API_KEY=your-dashscope-api-key
OPENAI_API_KEY=your-openai-api-key-here

# 合规违规词（逗号分隔，可动态通过环境变量更新）
VIOLATION_WORDS=保证赔付,100%理赔,无风险,稳赚,必赔

# 意图识别与问题改写模式：rule | llm | llm_vector（按业务场景选择）
INTENT_MODE=rule
REWRITE_MODE=rule
# llm_vector 模式使用的向量集合名
INTENT_RULES_COLLECTION=intent_rules
REWRITE_RULES_COLLECTION=rewrite_rules
INTENT_VECTOR_TOP_K=5
REWRITE_VECTOR_TOP_K=3

# 自训练 BERT 意图 API（独立服务器）：超时则兜底
# BERT_INTENT_API_URL=http://bert-server:8000/predict
# BERT_INTENT_TIMEOUT=2.0
# BERT_INTENT_FALLBACK_MODE=rule
# BERT_INTENT_REQUEST_QUERY_KEY=query

# Elasticsearch 配置
ES_HOST=localhost
ES_PORT=9200
ES_USER=
ES_PASSWORD=ZhiBao123**
